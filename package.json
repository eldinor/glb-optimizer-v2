{
  "name": "newsandbox",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src",
    "test:app": "vitest run src",
    "test:encoder": "npm run test --workspace babylonpress-ktx2-encoder",
    "test:all": "npm run test:app && npm run test:encoder"
  },
  "dependencies": {
    "@babylonjs/core": "^8.56.1",
    "@babylonjs/inspector": "^8.56.1",
    "@babylonjs/loaders": "^8.56.1",
    "@fluentui/react-components": "^9.73.4",
    "@fluentui/react-icons": "^2.0.321",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "ktx-parse": "^1.1.0",
    "babylonpress-ktx2-encoder": "file:./packages/babylonpress-ktx2-encoder",
    "meshoptimizer": "^0.20.0",
    "pixelmatch": "^5.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "~5.1.0",
    "vite": "^5.1.3",
    "vitest": "^4.1.0"
  }
}
